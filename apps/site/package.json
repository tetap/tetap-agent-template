{
  "name": "site",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vitepress dev src --host 127.0.0.1",
    "build": "vitepress build src",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "preview": "vitepress preview src --host 127.0.0.1",
    "clean": "rimraf dist src/.vitepress/cache .turbo"
  },
  "dependencies": {
    "@tetap/i18n": "workspace:*"
  },
  "devDependencies": {
    "vitepress": "^1.6.4",
    "vue": "^3.5.13"
  }
}
