model AdminUserSession {
  id             String    @id @default(uuid())
  adminUserId    String    @map("admin_user_id")
  tokenId        String    @unique @map("token_id")
  deviceType     String    @default("UNKNOWN") @map("device_type")
  ip             String
  userAgent      String    @map("user_agent")
  loginTime      DateTime  @default(now()) @map("login_time")
  lastActiveTime DateTime  @default(now()) @map("last_active_time")
  expiresAt      DateTime  @map("expires_at")
  status         String    @default("ONLINE")
  revokedAt      DateTime? @map("revoked_at")
  revokedReason  String?   @map("revoked_reason")
  tenantId       String?   @map("tenant_id")
  adminUser      AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, status])
  @@map("admin_user_sessions")
}
