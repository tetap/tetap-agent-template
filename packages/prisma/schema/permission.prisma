model Permission {
  id          BigInt           @id @default(autoincrement())
  code        String           @unique
  name        String
  type        String
  resource    String
  action      String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]
  menus       MenuPermission[]

  @@index([resource, action])
  @@map("permissions")
}
