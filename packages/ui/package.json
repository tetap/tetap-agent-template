    },
    "./tooltip": {
      "types": "./dist/components/ui/tooltip.d.ts",
      "import": "./dist/components/ui/tooltip.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "clean": "rimraf dist .turbo"
