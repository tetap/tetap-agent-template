{
  "name": "@tetap/ui",
  "version": "1.0.1",
  "description": "Shared shadcn/ui component library with brand assets, layout primitives, InputGroup, Select, and Sonner toast.",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "files": [
    "dist/**",
    "src/styles.css",
    "components.json",
    "tailwind.config.ts"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./brand-logo": {
      "types": "./dist/components/brand/tetap-logo.d.ts",
      "import": "./dist/components/brand/tetap-logo.js"
    },
    "./error-boundary": {
      "types": "./dist/components/error-boundary.d.ts",
      "import": "./dist/components/error-boundary.js"
    },
    "./styles.css": "./src/styles.css",
    "./alert": {
      "types": "./dist/components/ui/alert.d.ts",
      "import": "./dist/components/ui/alert.js"
    },
    "./avatar": {
      "types": "./dist/components/ui/avatar.d.ts",
      "import": "./dist/components/ui/avatar.js"
    },
