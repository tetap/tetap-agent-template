{
  "name": "@tetap/i18n",
  "version": "1.0.1",
  "description": "Shared internationalization utilities for React web and Node.js backends.",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist/**"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./public": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "import": "./dist/admin.js"
    },
    "./backend": {
      "types": "./dist/backend.d.ts",
      "import": "./dist/backend.js"
    },
    "./backend-admin": {
      "types": "./dist/backend-admin.d.ts",
      "import": "./dist/backend-admin.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./locales": {
      "types": "./dist/locales/index.d.ts",
      "import": "./dist/locales/index.js"
    }
  },
  "scripts": {
    "dev": "tsc -w --preserveWatchOutput -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "clean": "rimraf dist .turbo"
  },
  "peerDependencies": {
    "react": "19.2.6"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
