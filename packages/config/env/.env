# Shared defaults. All projects must read env through @tetap/config.
HOST=0.0.0.0
PORT=3000
BACKEND_ADMIN_HOST=0.0.0.0
BACKEND_ADMIN_PORT=3001
SKIP_ROUTES=/health,/api/health
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:5173,http://localhost:5174
BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
VITE_BACKEND_ADMIN_BASE_URL=http://127.0.0.1:3001

APP_ID=tetap-agent-template
APP_SECRET=dev-only-app-secret-change-me
AUTH_SALT=dev-only-auth-salt-change-me
AUTH_SECRET=dev-only-auth-secret-change-me
REFRESH_AUTH_SECRET=dev-only-refresh-auth-secret-change-me
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AES_SECRET_KEY=dev-only-aes-secret-key-32bytes!
AES_IV=dev-only-aes-iv!
