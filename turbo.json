{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-ssr/**"]
    },
    "@tetap/prisma#build": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "type-check": {
      "dependsOn": ["^build", "^type-check"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"],
      "cache": false
    },
    "lint:fix": {
      "cache": false
    },
    "clean": {
      "dependsOn": ["^clean"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:smoke": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "@tetap/test-automation#build": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:browser": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
