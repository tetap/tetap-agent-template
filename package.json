{
  "name": "tetap-agent-template",
  "version": "1.0.1",
  "description": "一个面向 Vibe Coding 的 全栈开发模板，包含前端、后端和数据库配置，旨在帮助开发者快速搭建和部署全栈应用。",
  "author": "TETAP",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "check": "pnpm versions:check && pnpm hooks:check && pnpm i18n:boundaries:check && pnpm backend:architecture:check && pnpm type-check && pnpm test:unit",
    "build": "pnpm check && pnpm version:bump && turbo build",
    "preview": "turbo preview",
    "type-check": "turbo type-check",
    "versions:check": "node scripts/check-dependency-versions.mjs",
    "i18n:boundaries:check": "node scripts/check-i18n-boundaries.mjs",
    "version:bump": "node scripts/update-version.mjs",
    "version:bump:dry": "node scripts/update-version.mjs --dry-run",
    "hooks:check": "node scripts/check-hooks-location.mjs",
    "lint": "pnpm versions:check && pnpm hooks:check && pnpm i18n:boundaries:check && pnpm backend:architecture:check && turbo lint --continue",
    "lint:fix": "turbo lint:fix --continue",
    "format": "prettier . --check --cache --cache-location node_modules/.cache/.prettiercache",
    "format:fix": "prettier . --write --cache --cache-location node_modules/.cache/.prettiercache",
    "db:schema:check": "pnpm --filter @tetap/prisma schema:check",
    "db:generate": "pnpm --filter @tetap/prisma generate",
    "db:validate": "pnpm --filter @tetap/prisma validate",
    "db:push": "pnpm --filter @tetap/prisma push",
    "db:studio": "pnpm --filter @tetap/prisma studio",
    "clean": "turbo clean && rimraf .turbo node_modules/.cache",
    "backend:architecture:check": "node scripts/check-backend-architecture.mjs",
    "test": "turbo test --continue",
    "test:unit": "turbo test:unit --continue",
    "test:smoke": "turbo test:smoke --continue",
    "test:browser": "turbo test:browser --continue",
    "test:target": "pnpm --filter @tetap/test-automation test:target --",
    "test:affected": "pnpm --filter @tetap/test-automation test:affected --",
    "test:unit:target": "pnpm --filter @tetap/test-automation test:unit:target --",
    "test:browser:target": "pnpm --filter @tetap/test-automation test:browser:target --",
    "test:smoke:target": "pnpm --filter @tetap/test-automation test:smoke:target --"
  },
  "engines": {
    "node": ">=22.22.2",
    "pnpm": ">=10.20.0"
  },
  "packageManager": "pnpm@10.20.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.68.0",
    "zod": "3.25.76"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.6",
      "react-dom": "19.2.6",
      "typescript": "6.0.3",
      "@hookform/resolvers": "5.2.2",
      "react-hook-form": "7.68.0",
      "zod": "3.25.76"
    }
  }
}
